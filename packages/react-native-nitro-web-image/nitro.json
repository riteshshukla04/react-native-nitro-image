{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["web", "image"],
  "ios": {
    "iosModuleName": "NitroWebImage"
  },
  "android": {
    "androidNamespace": ["web", "image"],
    "androidCxxLibName": "NitroWebImage"
  },
  "autolinking": {
    "WebImageFactory": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridWebImageFactory"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridWebImageFactory"
      }
    }
  },
  "ignorePaths": ["**/node_modules"]
}
